# ============================================
# ENHANCED SECURITY .HTACCESS
# Teas & C's PWA Ordering System
# ============================================

# 1. STOP CROSS-SITE CONTAMINATION (The "Jumping" Fix)
# This prevents a script in Site A from using a "Symlink" to read Site B.
Options -FollowSymLinks
Options +SymLinksIfOwnerMatch

# 2. DISABLE DIRECTORY BROWSING
# Prevents hackers from seeing your file structure
Options -Indexes

# 3. PROTECT YOUR CORE CONFIG FILES
# Block access to sensitive configuration files
<FilesMatch "^(\.htaccess|\.htpasswd|config\.php|php\.ini|error_log|\.env|\.git|\.gitignore)$">
    Order deny,allow
    Deny from all
</FilesMatch>

# 4. PROTECT SENSITIVE FILE TYPES
<FilesMatch "\.(log|sql|bak|backup|old|tmp|temp|swp|swo)$">
    Order deny,allow
    Deny from all
</FilesMatch>

# 5. BLOCK MALICIOUS SCRIPT INJECTIONS (Common Attack Patterns)
<IfModule mod_rewrite.c>
    RewriteEngine On
    
    # Skip security blocks for API requests (payment, products, orders)
    RewriteRule ^api/(create-payment-intent|products|orders|categories)\.php$ - [L]
    
    # Block script injection attempts
    RewriteCond %{QUERY_STRING} (<|%3C).*script.*(>|%3E) [NC,OR]
    RewriteCond %{QUERY_STRING} GLOBALS(=|\[|\%[0-9A-Z]{0,2}) [OR]
    RewriteCond %{QUERY_STRING} _REQUEST(=|\[|\%[0-9A-Z]{0,2}) [OR]
    RewriteCond %{QUERY_STRING} base64_encode.*\(.*\) [OR]
    RewriteCond %{QUERY_STRING} (\<|%3C).*iframe.*(\>|%3E) [NC,OR]
    RewriteCond %{QUERY_STRING} (\<|%3C).*object.*(\>|%3E) [NC,OR]
    RewriteCond %{QUERY_STRING} (\<|%3C).*embed.*(\>|%3E) [NC,OR]
    RewriteCond %{QUERY_STRING} (eval\(|exec\(|system\(|shell_exec|passthru) [NC,OR]
    RewriteCond %{QUERY_STRING} (javascript:).*(;|%3B) [NC,OR]
    RewriteCond %{QUERY_STRING} (\.\./|\.\.\\|\.\.%2F|\.\.%5C) [NC]
    RewriteRule ^(.*)$ - [F,L]
</IfModule>

# 6. DISABLE SERVER SIGNATURE (Hides server version info)
ServerSignature Off

# 7. PREVENT ACCESS TO HIDDEN FILES
<FilesMatch "^\.">
    Order deny,allow
    Deny from all
</FilesMatch>

# 8. ALLOW ACCESS TO ESSENTIAL FILES
# Allow index files
<FilesMatch "^(index\.html|index\.php)$">
    Order allow,deny
    Allow from all
</FilesMatch>
# Allow API PHP files (create-payment-intent, products, orders, categories)
<FilesMatch "^(create-payment-intent|products|orders|categories)\.php$">
    Order allow,deny
    Allow from all
</FilesMatch>

# 9. ALLOW IMAGE FILES
<FilesMatch "\.(jpg|jpeg|png|gif|webp|svg|ico|bmp|tiff)$">
    Order allow,deny
    Allow from all
</FilesMatch>

# 10. SECURITY HEADERS
<IfModule mod_headers.c>
    # Prevent clickjacking
    Header always set X-Frame-Options "SAMEORIGIN"
    
    # XSS Protection
    Header always set X-XSS-Protection "1; mode=block"
    
    # Prevent MIME type sniffing
    Header always set X-Content-Type-Options "nosniff"
    
    # Referrer Policy
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
    
    # Remove server information
    Header unset Server
    Header unset X-Powered-By
</IfModule>

# 11. DISABLE PHP EXECUTION IN UPLOAD DIRECTORIES (if any)
<IfModule mod_php.c>
    php_flag engine off
</IfModule>

# 12. LIMIT FILE UPLOAD SIZE (if mod_php is enabled)
<IfModule mod_php.c>
    php_value upload_max_filesize 10M
    php_value post_max_size 10M
</IfModule>
